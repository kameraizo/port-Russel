<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Catways - Port Russell</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-dark bg-dark">
        <div class="container">
            <a href="/dashboard" class="text-white text-decoration-none">⚓ Port de Plaisance Russell</a>
            <a href="/catways-page" class="btn btn-outline-light btn-sm me-2">Catways</a>
            <a href="/users-page" class="btn btn-outline-light btn-sm me-2">Utilisateurs</a>
            <a href="/reservations-page" class="btn btn-outline-light btn-sm me-2">Reservations</a></a>
            <a href="/users/logout" class="btn btn-outline-light btn-sm">Déconnexion</a>
        </div>
    </nav>

    <div class="container mt-4">
        <h2>Gestion des Catways</h2>

        <div class="card mt-3 mb-4">
            <div class="card-body">
                <h5 class="card-title">Ajouter un catway</h5>
                <form id="addCatwayForm">
                    <div class="row">
                        <div class="col-md-4">
                            <label class="form-label">Numero</label>
                            <input type="number" class="form-control" id="catwayNumber">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Type</label>
                            <select class="form-select" id="catwayType">
                                <option value="long">Long</option>
                                <option value="court">Court</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Etat</label>
                            <input type="text" class="form-control" id="catwayState">
                        </div>
                    </div>
                    <button type="submit" class="btn btn-dark mt-3">Ajouter</button>
                </form>
            </div>
        </div>
        
        <table class="table table-striped mt-3">
            <thead class="table-dark">
                <tr>
                    <th>Numéro</th>
                    <th>Type</th>
                    <th>État</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% catways.forEach(c => { %>
                <tr>
                    <td><%= c.catwayNumber %></td>
                    <td><%= c.catwayType %></td>
                    <td><%= c.catwayState %></td>
                    <td>
                        <button class="btn btn-danger btn-sm" onclick="deleteCatway('<%= c._id %>')">Supprimer</button>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
    <script> 
               async function deleteCatway(id) {
                if (!confirm('Etes-vous sur de vouloir supprimer ce catway ?')) return

                const token = localStorage.getItem('token')

                const response = await fetch('/catways/' + id, {
                    method: 'DELETE',
                    headers: {
                        'Authorization': token
                    }
                })
                if (response.ok) {
                    window.location.reload() // recharge la page pour afficher les nouvelles catways
                } else {
                    alert('Une erreur de supression !')
                }
            }
        document.getElementById('addCatwayForm').addEventListener('submit', async(e) => {
            e.preventDefault () //empeche le rechargement de la page


            

            const token = localStorage.getItem('token')

            const response = await fetch('/catways', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': token
                },
                body: JSON.stringify({
                    catwayNumber: document.getElementById('catwayNumber').value,
                    catwayType: document.getElementById('catwayType').value,
                    catwayState: document.getElementById('catwayState').value
                })
            })
            if (response.ok) {
                window.location.reload() // recharge la page pour afficher les nouvelles catways
            } else {
                alert('Une erreur de connexion !')
            }
        })
    </script>


</body>
</html>