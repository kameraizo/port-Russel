<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Dashboard - Port Russell</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-dark bg-dark">
        <div class="container">
            <span class="text-white">⚓ Port de Plaisance Russell</span>
            <a href="/catways-page" class="btn btn-outline-light btn-sm me-2">Catways</a>
            <a href="/users-page" class="btn btn-outline-light btn-sm me-2">Utilisateurs</a>
            <a href="/reservations-page" class="btn btn-outline-light btn-sm me-2">Reservations</a>
            <a href="/users/logout" class="btn btn-outline-light btn-sm">Déconnexion</a>
            <a href="https://github.com/kameraizo/port-Russel#readme" target="_blank" class="btn btn-outline-light btn-sm me-2">Documentation</a>
        </div>
    </nav>

    <div class="container mt-4">
        <h2>Tableau de bord</h2>
        <p class="text-muted">Connecté en tant que : <strong><%= username %></strong></p>
        <p class="text-muted">Date du jour : <strong><%= new Date().toLocaleDateString() %></strong></p>

        <h4 class="mt-4">Reservations en cours</h4>
        <table class="table table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Catway</th>
                    <th>Client</th>
                    <th>Bateau</th>
                    <th>Debut</th>
                    <th>Fin</th>
                </tr>
            </thead>
            <tbody>
                <% reservations.forEach(r => { %>
                    <tr>
                        <td><%= r.catwayNumber %></td>
                        <td><%= r.clientName %></td>
                        <td><%= r.boatName %></td>
                        <td><%= new Date(r.startDate).toLocaleDateString('fr-FR') %></td>
                        <td><%= new Date(r.endDate).toLocaleDateString('fr-FR') %></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</body>
</html>